# Per-machine Relay config.
#
# Copy to `relay.local.toml` (gitignored) and fill in for your machine.
# This file holds paths to project directories and references to secrets.
# Secrets themselves live in environment variables, not in this file.

# Who you are. Used to resolve agent nicknames and to attribute CLI actions.
user = "zach"

# --- Paths ---
#
# Where each project lives on disk. Tasks are created under
# `<path>/.relay/tasks/<id>-<slug>/`. Paths may be absolute or relative to
# the repo root. `~` is expanded.

[paths]
# Both demo and admin point inside this repo so smoke-testing the CLI
# never touches a real automation directory. If/when you migrate the
# existing automations into Relay, flip rd-tax to its real path then.
demo = "./projects/demo"
admin = "./projects/admin"
# rd-tax = "~/RD_Tax_Automation"   # uncomment when ready to migrate

# --- Secrets ---
#
# Reference environment variables with `env:VAR_NAME`. At launch time, the
# CLI resolves these to their current env values and injects them into the
# spawned process as uppercase env vars matching the key name.
#
# Leaving a secret unset is fine — the matching feature (e.g. Slack feed)
# silently no-ops.

[secrets]
slack_webhook = "env:SLACK_WEBHOOK_URL"
anthropic_api_key = "env:ANTHROPIC_API_KEY"
# Add per-project secrets as needed, e.g.:
# stripe_key = "env:STRIPE_SECRET_KEY"
# github_token = "env:GITHUB_TOKEN"
