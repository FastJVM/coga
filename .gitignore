# Relay local config — paths and secret references. Never commit.
# (Root-only; the bundled `example/` ships a non-secret template.)
/relay.local.toml

# Personal reference copies of the spec/vision docs live at repo root.
/relay-spec-updated*.md
/relay-vision-updated*.md

# Obsidian — per-machine workspace/theme/plugin config.
.obsidian/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/
# uv lock — not our build tool (project uses hatchling + `pip install -e .`).
uv.lock

# OS
.DS_Store
*.pem

# Env files
.env*

# Local secrets holding dir (interim home for SA keys etc. until the
# first-class relay config directory lands — see the config-directory ticket).
/.secrets/

# Local agent / tooling state
.claude/
.codex



# Per-task feature worktrees (see the dev/code context + `relay worktree`).
# Anchored to the git toplevel; kept ignored so the control-plane overlay
# plumbing never carries an in-flight worktree, and a stray `git clean -x`
# in the primary checkout can't reach committed worktree work.
/worktree/

# >>> relay-managed >>>
# Managed by `relay init [--update]`. Don't edit between these markers —
# they will be overwritten. Symlinks below are created by `relay init` so
# agent CLIs (Claude Code, Codex) can discover Relay's generated skill view.
.claude/skills/relay
.codex/skills/relay
# <<< relay-managed <<<
