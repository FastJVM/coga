# Relay local config — paths and secret references. Never commit.
# Anchored to repo root so the bundled template at
# relay-cli/src/relay_os/templates/relay.local.toml still tracks.
/relay.local.toml

# Obsidian — per-machine workspace/theme/plugin config.
.obsidian/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS
.DS_Store
*.pem

# Env files
.env*

# Personal reference copies of spec/vision docs (source of truth lives
# elsewhere; these are local working copies and shouldn't land on branches)
/relay-spec-updated*.md
/relay-vision-updated*.md


