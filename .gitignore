# Relay local config — paths and secret references. Never commit.
# (Root-only; the bundled `example/` ships a non-secret template.)
/relay.local.toml

# Relay slack-failure log — appended to whenever a Slack post fails after
# retries. Triage and clear manually.
relay-os/.slack-failures.log

# Personal reference copies of the spec/vision docs live at repo root.
/relay-spec-updated*.md
/relay-vision-updated*.md

# Obsidian — per-machine workspace/theme/plugin config.
.obsidian/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
venv/

# OS
.DS_Store
*.pem

# Env files
.env*

# Local agent / tooling state
.claude/
.codex



# >>> relay-managed >>>
# Managed by `relay init [--update]`. Don't edit between these markers —
# they will be overwritten. Symlinks below are created by `relay init` so
# agent CLIs (Claude Code, Codex) can discover relay-os/skills/.
.claude/skills/relay
.codex/skills/relay
# <<< relay-managed <<<
