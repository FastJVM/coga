# Machine-local config — paths and secrets. Never commit.
relay.local.toml

# Task locks — local file-existence locks, not meant to be shared.
**/task.lock

# Vendored CLI — managed by `relay update`, refreshed from upstream.
.relay/

# Upstream-managed launch shim and bootstrap skills — refreshed by
# `relay init [--update]`. Tracking them creates churn.
/bootstrap/
/skills/bootstrap/
