#!/bin/sh
# Auto-bump relay tickets whose linked PR has merged.
#
# Symlinked into .git/hooks/post-merge by `relay init` (and `init --update`).
# Best-effort: never blocks the pull. If `relay` isn't on PATH, the
# `relay status` opportunistic fallback will catch up the next time
# someone runs it.

if command -v relay >/dev/null 2>&1; then
    relay automerge || true
fi
