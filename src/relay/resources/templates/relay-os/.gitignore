# Machine-local config — paths and secrets. Never commit.
relay.local.toml

# Task locks — local file-existence locks, not meant to be shared.
**/task.lock

# Vendored CLI — refreshed by `relay init --update` from upstream.
.relay/

# Upstream-managed scaffolding — overwritten on every `relay init --update`.
# User content lives outside these paths; edits inside will be lost on update.
bootstrap/
skills/bootstrap/
skills/retro/
contexts/relay/architecture/
contexts/relay/principles/
contexts/relay/cli/
**/_template/
**/_template.md
